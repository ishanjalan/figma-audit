{
  "name": "figma-audit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "audit": "node --env-file=.env --import tsx/esm src/index.ts",
    "discover": "node --env-file=.env --import tsx/esm src/discover.ts",
    "handover-watch": "node --env-file=.env --import tsx/esm src/handover-watch.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "webhook:register": "node --env-file=.env --import tsx/esm src/webhook/register.ts --action register",
    "webhook:list":     "node --env-file=.env --import tsx/esm src/webhook/register.ts --action list",
    "webhook:delete":   "node --env-file=.env --import tsx/esm src/webhook/register.ts --action delete"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
