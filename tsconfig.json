{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@rules/*": ["./packages/handover-rules/src/*"]
    }
  },
  "include": ["src/**/*.ts", "packages/handover-rules/src/**/*.ts"]
}
