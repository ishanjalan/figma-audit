FIGMA_TOKEN=          # Personal access token (Figma Settings → Account → Personal access tokens)
FIGMA_ORG_ID=         # Enterprise org ID (from figma.com/files/ORG_ID/admin)
FIGMA_TEAM_ID=        # Alternative to ORG_ID — limits to one team
FIGMA_PROJECT_IDS=    # Alternative to org/team — comma-separated project IDs
                      # Find in URL: figma.com/files/project/PROJECT_ID/...
GCHAT_WEBHOOK_URL=    # Google Chat space → Manage webhooks → Add
